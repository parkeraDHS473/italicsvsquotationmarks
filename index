function shuffle(a){return[...a].sort(()=>Math.random()-0.5);}
let pool=[], score=0, lives=3, streak=0, current=null, busy=false, missed=[];
let animFrame=null, startTime=null, duration=0;
let ARENA_H=460, CRASH_Y=390;
const PAD_H=60, ROCKET_H=419;
const BASE_DURATION=11000, MIN_DURATION=5000;

function renderLives(){ document.getElementById('lives').innerHTML=[0,1,2].map(i=>`<span>${i<lives?'♥':'♡'}</span>`).join(''); }
function updateHUD(){ document.getElementById('score-val').textContent=score; document.getElementById('streak-val').textContent=streak; renderLives(); }
function buildSentence(q){ return q.sentence.replace(/\{(.+?)\}/,'<span class="target">$1</span>'); }

function drawStars(){
  const canvas=document.getElementById('stars');
  canvas.width=canvas.offsetWidth||620; canvas.height=canvas.offsetHeight||ARENA_H;
  const ctx=canvas.getContext('2d'); ctx.clearRect(0,0,canvas.width,canvas.height);
  for(let i=0;i<80;i++){
    const x=Math.random()*canvas.width, y=Math.random()*canvas.height*0.85;
    const r=Math.random()*1.3+0.2, a=Math.random()*0.6+0.2;
    ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2);
    ctx.fillStyle=`rgba(200,210,255,${a})`; ctx.fill();
  }
}

function setRocketPos(yPx,xPct){
  const wrap=document.getElementById('rocket-wrap');
  wrap.style.top=yPx+'px';
  if(xPct!==undefined){ wrap.style.left=xPct+'%'; wrap.style.transform='translateX(-50%)'; }
}

function loadCard(){
  if(!pool.length) pool=shuffle(Qs);
  current=pool.pop(); busy=false;
  document.getElementById('card-sentence').innerHTML=buildSentence(current);
  document.getElementById('feedback').textContent='';
  document.getElementById('pad-italics').className='pad';
  document.getElementById('pad-quotes').className='pad';
  document.getElementById('pad-italics').disabled=false;
  document.getElementById('pad-quotes').disabled=false;
  const wrap=document.getElementById('rocket-wrap');
  wrap.style.transition='none'; setRocketPos(-ROCKET_H,50);
  duration=Math.max(MIN_DURATION,BASE_DURATION-Math.floor(score/30)*200);
  startTime=null;
  if(animFrame) cancelAnimationFrame(animFrame);
  requestAnimationFrame(descend);
}

function descend(ts){
  if(busy) return;
  if(!startTime) startTime=ts;
  const elapsed=ts-startTime, progress=Math.min(elapsed/duration,1);
  const travelY=CRASH_Y+ROCKET_H;
  setRocketPos(-ROCKET_H+progress*travelY);
  const bar=document.getElementById('timer-bar'), pct=1-progress;
  bar.style.width=(pct*100)+'%';
  bar.style.background=pct<0.3?'#D85A30':pct<0.6?'#EF9F27':'#378ADD';
  if(progress>=1){ crashed(); return; }
  animFrame=requestAnimationFrame(descend);
}

function crashed(){
  busy=true; cancelAnimationFrame(animFrame);
  lives--; streak=0;
  if(current && !missed.some(m=>m.rule===current.rule)) missed.push(current);
  document.getElementById('pad-italics').disabled=true;
  document.getElementById('pad-quotes').disabled=true;
  document.getElementById('feedback').textContent='💥 Crashed! '+current.rule;
  updateHUD();
  if(lives<=0){ setTimeout(endGame,2500); return; }
  setTimeout(()=>{ loadCard(); },2500);
}

function answer(choice){
  if(busy) return;
  busy=true; cancelAnimationFrame(animFrame);
  document.getElementById('pad-italics').disabled=true;
  document.getElementById('pad-quotes').disabled=true;
  const correct=choice===current.ans;
  const wrap=document.getElementById('rocket-wrap');
  const targetLeft=choice==='italics'?14:72;
  wrap.style.transition='left 0.3s ease, top 0.4s ease';
  wrap.style.left=targetLeft+'%'; wrap.style.transform='translateX(-50%)';
  setTimeout(()=>{ wrap.style.top=(CRASH_Y-10)+'px'; },50);
  document.getElementById('timer-bar').style.width='0%';
  if(correct){
    score+=10+streak*2; streak++;
    document.getElementById('pad-'+choice).className='pad correct-flash';
    document.getElementById('feedback').textContent=(streak>2?`🔥 +${10+(streak-1)*2} pts — `:'✓ Correct! — ')+current.rule;
  } else {
    lives--; streak=0;
    if(current && !missed.some(m=>m.rule===current.rule)) missed.push(current);
    document.getElementById('pad-'+choice).className='pad wrong-flash';
    const label=current.ans==='italics'?'italics':'quotation marks';
    document.getElementById('feedback').textContent=`✗ Needed ${label}! — `+current.rule;
  }
  updateHUD();
  if(lives<=0){ setTimeout(endGame,2500); return; }
  setTimeout(()=>{ loadCard(); },2500);
}

function endGame(){
  cancelAnimationFrame(animFrame);
  document.getElementById('end').style.display='flex';
  const tier=score>=120?'high':score>=50?'mid':'low';
  const titles={high:'🏆 Formatting expert!',mid:'⭐ Nice work!',low:'Good try!'};
  const msgs={
    high:`You scored ${score} points — you really know your italics from your quotation marks!`,
    mid:`You scored ${score} points — keep practicing and you'll be a formatting pro!`,
    low:`You scored ${score} points — review the rules and give it another go!`
  };
  document.getElementById('end-title').textContent=titles[tier];
  document.getElementById('end-msg').textContent=msgs[tier];
  const panel=document.getElementById('missed-rules');
  const list=document.getElementById('missed-rules-list');
  list.innerHTML='';
  if(missed.length){
    missed.forEach(q=>{
      const div=document.createElement('div');
      div.className='missed-rule-item';
      div.textContent=q.rule;
      list.appendChild(div);
    });
    panel.style.display='flex';
  } else {
    panel.style.display='none';
  }
}

function startGame(){
  ARENA_H = document.getElementById('arena').offsetHeight || 460;
  CRASH_Y = ARENA_H - PAD_H - 10;
  score=0; lives=3; streak=0; pool=shuffle(Qs); missed=[];
  cancelAnimationFrame(animFrame);
  document.getElementById('end').style.display='none';
  document.getElementById('start').style.display='none';
  document.getElementById('pad-italics').className='pad';
  document.getElementById('pad-quotes').className='pad';
  document.getElementById('feedback').textContent='';
  updateHUD(); drawStars(); loadCard();
}

document.getElementById('launch-btn').onclick = startGame;
document.getElementById('restart').onclick = startGame;
document.getElementById('pad-italics').onclick = () => answer('italics');
document.getElementById('pad-quotes').onclick = () => answer('quotes');

drawStars();
updateHUD();
</script>
