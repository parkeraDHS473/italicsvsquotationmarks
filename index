<!DOCTYPE html>
<html><head><style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body { font-family: sans-serif; }
#app { width: 100%; max-width: 620px; margin: 0 auto; padding: 0.5rem 1rem; height: 100vh; display: flex; flex-direction: column; }
#hud { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; flex-shrink: 0; }
.pill { background: #f0f0f0; border: 0.5px solid #ddd; border-radius: 999px; padding: 5px 14px; font-size: 13px; color: #555; }
.pill span { font-weight: 500; color: #111; }
#lives { font-size: 17px; display: flex; gap: 3px; }
#arena {
  position: relative; width: 100%; flex: 1;
  background: #0a0a1a; border-radius: 12px; overflow: hidden; margin-bottom: 0;
}
#stars { position: absolute; inset: 0; pointer-events: none; }
#rocket-wrap {
  position: absolute; left: 50%; transform: translateX(-50%);
  top: -419px; width: 290px; text-align: center; pointer-events: none;
}
#rocket-inner { position: relative; display: inline-block; }
#rocket-overlay {
  position: absolute;
  top: 53%; left: 24%; width: 49%; height: 25%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 4px; overflow: hidden;
}
#card-cat { display: none; }
#card-sentence { font-size: 13px; color: #111; line-height: 1.4; word-break: break-word; }
#card-sentence .target { background: #E6F1FB; color: #185FA5; border-radius: 3px; padding: 0 3px; font-weight: 600; }
#pads {
  position: absolute; bottom: 0; left: 0; right: 0;
  display: flex; justify-content: space-between; padding: 0 8px 8px; pointer-events: none;
}
.pad {
  width: 28%; border-radius: 6px 6px 0 0;
  border: 2px solid; border-bottom: none; padding: 0.5rem 0.4rem; text-align: center;
  cursor: pointer; font-size: 13px; font-weight: 600;
  transition: background 0.15s, border-color 0.2s, opacity 0.15s;
  pointer-events: all; min-height: 52px;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  box-shadow: inset 0 3px 0 rgba(255,255,255,0.15), 0 0 12px rgba(0,0,0,0.5);
  letter-spacing: 0.02em;
}
.pad::after {
  content: '';
  position: absolute; bottom: 0; left: 10%; right: 10%; height: 4px;
  background: repeating-linear-gradient(90deg, rgba(255,220,0,0.8) 0px, rgba(255,220,0,0.8) 8px, transparent 8px, transparent 14px);
  border-radius: 2px;
}
#pad-italics {
  background: linear-gradient(180deg, rgba(100,80,160,0.6) 0%, rgba(60,45,110,0.8) 100%);
  border-color: #9c7de0; color: #ede7f6;
}
#pad-italics:hover {
  background: linear-gradient(180deg, rgba(130,105,200,0.7) 0%, rgba(80,60,150,0.85) 100%);
  border-color: #c4a8f0;
}
#pad-quotes {
  background: linear-gradient(180deg, rgba(30,100,180,0.6) 0%, rgba(15,60,120,0.8) 100%);
  border-color: #4a9de0; color: #e3f2fd;
}
#pad-quotes:hover {
  background: linear-gradient(180deg, rgba(50,130,220,0.7) 0%, rgba(20,80,160,0.85) 100%);
  border-color: #80c4f8;
}
.pad.correct-flash { background: rgba(29,158,117,0.5) !important; border-color: #4dd0a4 !important; color: #ccf5e7 !important; }
.pad.wrong-flash   { background: rgba(216,90,48,0.5)  !important; border-color: #f0825a !important; color: #fde0d5 !important; }
#pads { z-index: 2; align-items: flex-end; }
#terrain-center { flex: 1; margin: 0 6px; align-self: stretch; overflow: hidden; pointer-events: none; }
#timer-bar-wrap { position: absolute; top: 0; left: 0; right: 0; height: 3px; }
#timer-bar { height: 3px; width: 100%; border-radius: 0 2px 2px 0; }
#feedback {
  position: absolute; bottom: 150px; left: 50%; transform: translateX(-50%);
  width: 90%; text-align: center; font-size: 14px; color: rgba(255,255,255,0.85);
  line-height: 1.5; pointer-events: none; z-index: 3; font-weight: 500;
}
#end {
  display: none; position: absolute; inset: 0; background: rgba(10,10,26,0.92);
  border-radius: 12px; flex-direction: column;
  align-items: center; justify-content: flex-start; gap: 0.75rem; text-align: center;
  padding: 2rem 1.5rem 1.5rem; overflow-y: auto;
}
#end h3 { font-size: 22px; font-weight: 500; color: #fff; margin-top: 1rem; }
#end p { font-size: 14px; color: rgba(255,255,255,0.6); }
#missed-rules {
  width: 100%; max-height: 42vh; overflow-y: auto;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px; padding: 0.8rem 1rem; text-align: left;
  display: none; flex-direction: column; gap: 0.5rem;
}
#missed-rules h4 {
  font-size: 13px; font-weight: 700; color: rgba(255,200,80,0.9);
  text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.4rem;
}
.missed-rule-item {
  font-size: 12px; color: rgba(255,255,255,0.75); line-height: 1.5;
  padding: 0.45rem 0.6rem; border-radius: 6px;
  background: rgba(255,255,255,0.05); border-left: 3px solid rgba(100,130,255,0.6);
}
#restart {
  padding: 0.65rem 1.75rem; border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.1);
  cursor: pointer; font-size: 14px; font-weight: 500; color: #fff; margin-top: 0.5rem;
}
#restart:hover { background: rgba(255,255,255,0.2); }
#start {
  display: flex; position: absolute; inset: 0; background: #0a0a1a;
  border-radius: 12px; flex-direction: column;
  align-items: center; justify-content: center; gap: 1.1rem;
  text-align: center; padding: 2rem; z-index: 10;
}
#start h1 { font-size: 28px; font-weight: 700; color: #fff; line-height: 1.2; text-shadow: 0 0 30px rgba(100,160,255,0.4); }
#start h1 em { font-style: italic; color: #c4a8f0; }
#start h1 span { color: #80c4f8; }
#start .tagline { font-size: 14px; color: rgba(255,255,255,0.5); max-width: 300px; line-height: 1.5; }
#start-rocket { animation: bob 3s ease-in-out infinite; }
@keyframes bob { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-14px); } }
#launch-btn {
  padding: 0.8rem 2.5rem; border-radius: 999px; border: none;
  background: linear-gradient(135deg, #6a3de8, #2979d8);
  box-shadow: 0 0 24px rgba(100,130,255,0.5), 0 4px 12px rgba(0,0,0,0.4);
  cursor: pointer; font-size: 17px; font-weight: 700; color: #fff;
  letter-spacing: 0.08em; text-transform: uppercase;
  transition: transform 0.15s, box-shadow 0.15s;
}
#launch-btn:hover { transform: scale(1.06); box-shadow: 0 0 36px rgba(120,160,255,0.7), 0 6px 18px rgba(0,0,0,0.5); }
